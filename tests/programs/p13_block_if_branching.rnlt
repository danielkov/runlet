#! expect: { "tiers": ["standard", "vip", "basic"], "written": 1 }
#! writes: 1
# Block-if branching: multi-statement branches, else-if chains, effect
# gating (only the selected branch's write dispatches), and the optional
# else defaulting to null inside a keyed fold.
orders = data.orders()
tiers = for o in orders limit 4 {
    tier = if o.customer.tier >= 3 {
        flagged = write.update({ id: o.id, company: "priority-desk" })
        return "vip"
    } else if o.customer.tier == 2 {
        return "standard"
    } else {
        return "basic"
    }
    return tier
}
written = fold n = 0 for o in orders {
    bump = if o.customer.tier >= 3 { return 1 }
    return n + (bump if bump != null else 0)
}
return { tiers: tiers, written: written }
