#! expect: { "top": "o2", "bottom": "o3", "window": ["o1", "o2"], "pages": [1, 2, 3] }
orders = data.orders()
ranked = list.sort_by(orders, "customer.tier", "desc")
by_id = list.sort_by(orders, "id")
return {
    top: ranked[0].id,
    bottom: ranked[2].id,
    window: for o in list.slice(by_id, 0, 2) limit 2 { return o.id },
    pages: list.range(1, 4)
}
